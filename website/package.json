{
  "name": "sigo-website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev --config ./wrangler.jsonc",
    "astro": "astro",
    "deploy:staging": "astro build && wrangler deploy --env staging --config ./wrangler.jsonc",
    "deploy": "astro build && wrangler deploy --env prod --config ./wrangler.jsonc",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "astro": "^6.1.2",
    "wrangler": "^4.72.0",
    "@astrojs/cloudflare": "^13.1.5",
    "@astrojs/sitemap": "^3.7.2",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0"
  },
  "devDependencies": {
    "@coreui/icons": "^3.0.1",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/mdi": "^1.2.3",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5",
    "wrangler": "^4.78.0"
  },
  "packageManager": "pnpm@10.33.0"
}
