---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
---

<Layout title="404 | Should I Go Outside?">
  <Header />
  <main class="page">
    <div class="card">
      <span class="emoji">🌧️</span>
      <h1 class="title">Nope.</h1>
      <p class="subtitle">This page doesn't exist.<br />Maybe stay inside.</p>
      <a href="/" class="brutal-btn btn">Go Home</a>
    </div>
  </main>
</Layout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    background-color: var(--color-bg);
  }

  .card {
    text-align: center;
    background-color: var(--color-surface);
    border: var(--border-width) solid var(--color-outline);
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 0
      var(--color-shadow);
    border-radius: var(--radius-md);
    padding: 3rem 2.5rem;
    max-width: 420px;
    width: 100%;
    animation: wobble 3s ease-in-out infinite;
  }

  @keyframes wobble {
    0%,
    100% {
      transform: rotate(-1.5deg);
    }
    50% {
      transform: rotate(1deg);
    }
  }

  .emoji {
    font-size: 4rem;
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }

  .title {
    font-family: "Lexend Mega", sans-serif;
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 0.91;
    letter-spacing: -0.156em;
    color: var(--color-coral);
    -webkit-text-stroke: 2px var(--color-outline);
    paint-order: stroke fill;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .btn {
    padding: 0.85rem 2rem;
    font-size: var(--text-base);
    background-color: var(--color-primary);
  }

  @media (prefers-reduced-motion: reduce) {
    .card {
      animation: none;
      transform: rotate(-1.5deg);
    }
  }
</style>
