---
import screenshotYes from "../assets/screenshot_yes.png"
---

<section class="preview-section">
  <div class="container">
    <!-- Section header -->
    <div class="preview-header">
      <span class="preview-eyebrow">No fluff. No forecast maps.</span>
      <h2 class="preview-title reveal">See It In Action</h2>
    </div>

    <!-- Stage: two phones side by side -->
    <div class="preview-stage">
      <!-- Decorative blobs behind the phones -->
      <div class="stage-blob stage-blob--yellow" aria-hidden="true"></div>
      <div class="stage-blob stage-blob--coral" aria-hidden="true"></div>

      <!-- Android -->
      <div class="phone-wrap phone-wrap--android reveal reveal-delay-2">
        <div class="phone phone--android">
          <img
            src={screenshotYes.src}
            alt="Should I Go Outside app on Android showing a YES answer with sunny weather"
            class="phone-screenshot"
            width={screenshotYes.width}
            height={screenshotYes.height}
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <!-- Caption -->
    <p class="preview-caption">
      Available on iOS and Android. Really that simple.
    </p>
  </div><!-- /container -->
</section>

<style>
  .preview-section {
    padding: 6rem 1.5rem 7rem;
    background-color: var(--color-bg);
    overflow: hidden;
  }

  .container {
    max-width: 1040px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .preview-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .preview-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background-color: var(--color-primary);
    border: var(--border-width) solid var(--color-outline);
    padding: 0.25rem 0.85rem;
    border-radius: var(--radius-sm);
    box-shadow: 3px 3px 0 0 var(--color-shadow);
  }

  .preview-title {
    font-family: "Lexend Mega", sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 0.93;
    color: var(--color-text);
    letter-spacing: -0.2em;
    display: inline-block;
    position: relative;
  }

  .preview-title::after {
    content: "";
    display: block;
    height: 6px;
    background-color: var(--color-text);
    margin-top: 0.3rem;
    border-radius: 2px;
  }

  /* ── Stage ── */
  .preview-stage {
    position: relative;
    width: 100%;
    max-width: 700px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 3rem 1rem;
    gap: 4rem;
  }

  /* Decorative blobs */
  .stage-blob {
    position: absolute;
    border-radius: 50%;
    z-index: 0;
  }

  .stage-blob--yellow {
    width: 260px;
    height: 260px;
    background-color: var(--color-primary);
    border: var(--border-width) solid var(--color-outline);
    top: -10px;
    left: 50%;
    transform: translateX(-75%) rotate(-8deg);
  }

  .stage-blob--coral {
    width: 180px;
    height: 180px;
    background-color: var(--color-accent);
    border: var(--border-width) solid var(--color-outline);
    bottom: 0;
    right: 3%;
  }

  /* ── Phone wrappers ── */
  .phone-wrap {
    position: relative;
    z-index: 1;
  }

  .phone-wrap--iphone {
    transform: rotate(-2deg) translateY(-12px);
    z-index: 2;
  }

  .phone-wrap--android {
    transform: rotate(2.5deg) translateY(12px);
    z-index: 1;
  }

  /* ── Shared phone base ── */
  .phone {
    position: relative;
    background-color: var(--color-outline);
    overflow: hidden;
  }

  .phone-screenshot {
    display: block;
    width: 100%;
    height: auto;
    position: relative;
  }

  /* ══════════════════════════════
     iPhone — thick bezel, big radius, Dynamic Island
     ══════════════════════════════ */
  .phone--iphone {
    width: 240px;
    border-radius: 36px;
    border: 3px solid var(--color-outline);
    padding: 5px;
    box-shadow: -6px 8px 0 0 var(--color-shadow);
  }

  .phone--iphone .phone-screenshot {
    border-radius: 31px;
  }

  /* Dynamic Island — sits on top of the screenshot */
  .dynamic-island {
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 72px;
    height: 20px;
    background-color: var(--color-outline);
    border-radius: 20px;
    z-index: 3;
  }

  /* Volume buttons (left side) */
  .phone--iphone::before {
    content: "";
    position: absolute;
    top: 110px;
    left: -7px;
    width: 4px;
    height: 28px;
    background-color: var(--color-outline);
    border-radius: 3px 0 0 3px;
    /* Second volume button + silent switch via shadows */
    box-shadow:
      0 -14px 0 0 var(--color-outline),
      0 36px 0 0 var(--color-outline);
  }

  /* Power button (right side) */
  .phone--iphone::after {
    content: "";
    position: absolute;
    top: 120px;
    right: -7px;
    width: 4px;
    height: 44px;
    background-color: var(--color-outline);
    border-radius: 0 3px 3px 0;
  }

  /* ══════════════════════════════
     Android — thin bezel, tight radius, minimal frame
     ══════════════════════════════ */
  .phone--android {
    width: 240px;
    border-radius: 20px;
    border: 2px solid var(--color-outline);
    padding: 4px;
    box-shadow: 6px 8px 0 0 var(--color-shadow);
  }

  .phone--android .phone-screenshot {
    border-radius: 16px;
  }

  /* Power button (right side) */
  .phone--android::after {
    content: "";
    position: absolute;
    top: 90px;
    right: -4px;
    width: 3px;
    height: 36px;
    background-color: var(--color-outline);
    border-radius: 0 2px 2px 0;
  }

  /* ── Caption ── */
  .preview-caption {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-align: center;
    line-height: 1.5;
    letter-spacing: 0;
    position: relative;
    display: inline-block;
  }

  .preview-caption::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 3px;
    background-color: var(--color-primary);
    border-radius: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 580px) {
    .preview-stage {
      gap: 2.5rem;
    }

    .phone--iphone {
      width: 170px;
      border-radius: 28px;
      padding: 4px;
    }

    .phone--iphone .phone-screenshot {
      border-radius: 24px;
    }

    .dynamic-island {
      width: 50px;
      height: 14px;
      top: 9px;
    }

    .phone--android {
      width: 170px;
      border-radius: 16px;
      padding: 3px;
    }

    .phone--android .phone-screenshot {
      border-radius: 13px;
    }

    .stage-blob--yellow {
      width: 170px;
      height: 170px;
    }

    .stage-blob--coral {
      width: 110px;
      height: 110px;
      right: 0;
    }
  }
</style>
