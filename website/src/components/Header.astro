---
import { Image } from "astro:assets"
import appIcon from "../assets/icon.png"
---

<header class="site-header">
  <div class="header__inner">
    <a href="/" class="header__brand" aria-label="Should I Go Outside? Home">
      <Image
        src={appIcon}
        alt=""
        class="header__icon"
        width={32}
        height={32}
        loading="eager"
      />
      <span class="header__name">Should I Go Outside?</span>
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      <a href="/help" class="header__link">Help</a>
      <a href="#download" class="brutal-btn brutal-btn--sm header__cta"
        >Download</a
      >
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: var(--color-bg);
    border-bottom: var(--border-width) solid var(--color-outline);
    padding: 0 var(--space-md);
  }

  .header__inner {
    max-width: 1100px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .header__brand:hover {
    transform: rotate(-1.5deg) scale(1.03);
  }

  .header__icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 2px solid var(--color-outline);
    box-shadow: 2px 2px 0 0 var(--color-shadow);
    flex-shrink: 0;
  }

  .header__name {
    font-family: "Lexend Mega", sans-serif;
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--display-tracking);
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .header__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 120ms ease;
  }

  .header__link:hover {
    color: var(--color-text);
  }

  .header__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .header__cta {
    font-size: var(--text-sm);
    background-color: var(--color-primary);
    padding: 0.45rem 1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .header__brand {
      transition: none;
    }
    .header__brand:hover {
      transform: none;
    }
  }
</style>
