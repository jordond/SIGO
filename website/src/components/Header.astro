---

---

<header class="site-header">
  <div class="header__inner">
    <a href="/" class="header__brand" aria-label="Should I Go Outside? — Home">
      <span class="header__name">SIGO</span>
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      <a href="/help" class="header__link">Help</a>
      <a
        href="https://apps.apple.com/us/app/should-i-go-outside-weather/id6760564555"
        class="header__cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Download
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: var(--color-bg);
    border-bottom: var(--border-width) solid var(--color-outline);
    padding: 0 var(--space-md);
  }

  .header__inner {
    max-width: 1100px;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .header__brand {
    text-decoration: none;
    color: var(--color-text);
  }

  .header__name {
    font-family: "Lexend Mega", sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.12em;
    text-transform: uppercase;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .header__link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 120ms ease;
  }

  .header__link:hover {
    color: var(--color-text);
  }

  .header__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    background-color: var(--color-primary);
    border: var(--border-width) solid var(--color-outline);
    border-radius: var(--radius-sm);
    padding: 0.45rem 1rem;
    box-shadow: 3px 3px 0 0 var(--color-shadow);
    transform: translate(0, 0);
    transition:
      transform 120ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 120ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .header__cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 0 var(--color-shadow);
  }

  .header__cta:active {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0 0 var(--color-shadow);
  }

  .header__cta:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .header__cta {
      transition: none;
    }
  }
</style>
