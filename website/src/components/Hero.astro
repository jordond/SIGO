---
// Hero.astro — "Should I Go Outside?" landing hero
// Neobrutalism: chunky borders, hard shadows, bright pops of color, a tilted headline card
---

<section class="hero">
  <div class="bg-shapes" aria-hidden="true">
    <div class="shape shape--circle-lg"></div>
    <div class="shape shape--square"></div>
    <div class="shape shape--circle-sm"></div>
    <div class="shape shape--rect"></div>
    <div class="shape shape--dot dot-1"></div>
    <div class="shape shape--dot dot-2"></div>
    <div class="shape shape--dot dot-3"></div>
    <div class="shape shape--squiggle">
      <svg viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M4 20 C20 4, 36 36, 52 20 C68 4, 84 36, 100 20 C108 12, 114 16, 118 20"
          stroke="currentColor"
          stroke-width="5"
          stroke-linecap="round"
          fill="none"></path>
      </svg>
    </div>
    <div class="shape shape--squiggle squiggle-2">
      <svg viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M4 20 C20 4, 36 36, 52 20 C68 4, 84 36, 100 20 C108 12, 114 16, 118 20"
          stroke="currentColor"
          stroke-width="5"
          stroke-linecap="round"
          fill="none"></path>
      </svg>
    </div>
  </div>

  <!-- Main content -->
  <div class="hero__inner">
    <!-- Tilted headline card -->
    <div class="hero__title-card">
      <h1 class="hero__title">Should I<br />Go Outside?</h1>
    </div>

    <!-- Tagline -->
    <p class="hero__tagline">
      The weather app that answers<br class="tagline-break" /> the only question that
      matters.
    </p>

    <!-- Description -->
    <p class="hero__description">
      No radar maps. No pollen counts. No 10-day forecasts you'll never read.<br
        class="desc-break"
      />
      Just the answer you actually need.
    </p>

    <!-- CTA buttons -->
    <div class="hero__ctas">
      <a
        href="#"
        class="btn btn--ios"
        aria-label="Download for iOS on the App Store"
      >
        <span class="btn__icon" aria-hidden="true">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
        </span>
        <span class="btn__text">
          <span class="btn__label">Download for</span>
          <span class="btn__platform">iOS</span>
        </span>
      </a>

      <a
        href="#"
        class="btn btn--android"
        aria-label="Download for Android on the Play Store"
      >
        <span class="btn__icon" aria-hidden="true">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M3 18.5v-13c0-.83.94-1.3 1.6-.8l11 6.5c.6.35.6 1.25 0 1.6l-11 6.5c-.66.5-1.6.03-1.6-.8zm1.5-11.3v9.6l8.3-4.8-8.3-4.8z"
            ></path>
            <path d="M3.5 5.5l8.5 5M3.5 18.5l8.5-5"></path>
            <path
              d="M17.5 6.5 L21.5 12 L17.5 17.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"></path>
            <path
              d="M3.5 5.5 L17.5 6.5 M3.5 18.5 L17.5 17.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              fill="none"></path>
          </svg>
        </span>
        <span class="btn__text">
          <span class="btn__label">Download for</span>
          <span class="btn__platform">Android</span>
        </span>
      </a>
    </div>

    <!-- Scroll nudge -->
    <div class="hero__scroll-nudge" aria-hidden="true">
      <span class="scroll-label">scroll to find out more</span>
      <svg
        class="scroll-arrow"
        width="20"
        height="24"
        viewBox="0 0 20 28"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="10"
          y1="0"
          x2="10"
          y2="20"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"></line>
        <polyline
          points="3,14 10,22 17,14"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"></polyline>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg);
    overflow: hidden;
    padding: 6rem 1.5rem 5rem;
  }

  .bg-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .shape {
    position: absolute;
    border: var(--border-width) solid var(--color-outline);
  }

  /* Large circle — top left */
  .shape--circle-lg {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background-color: var(--color-secondary);
    top: -80px;
    left: -80px;
    opacity: 0.45;
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 0
      var(--color-outline);
    animation: float-a 7s ease-in-out infinite;
  }

  /* Tilted square — top right */
  .shape--square {
    width: 140px;
    height: 140px;
    border-radius: var(--radius-sm);
    background-color: var(--color-tertiary);
    top: 60px;
    right: 8%;
    opacity: 0.35;
    transform: rotate(18deg);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    animation: float-b 9s ease-in-out infinite;
  }

  /* Small circle — right mid */
  .shape--circle-sm {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background-color: var(--color-mint);
    right: 12%;
    bottom: 22%;
    opacity: 0.5;
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    animation: float-a 6s ease-in-out infinite reverse;
  }

  /* Rectangle — bottom left */
  .shape--rect {
    width: 200px;
    height: 80px;
    border-radius: var(--radius-sm);
    background-color: var(--color-orange);
    bottom: 10%;
    left: 4%;
    opacity: 0.3;
    transform: rotate(-8deg);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    animation: float-b 8s ease-in-out infinite;
  }

  /* Dots */
  .shape--dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: none;
  }

  .dot-1 {
    background: var(--color-primary);
    top: 18%;
    left: 18%;
    opacity: 0.9;
    box-shadow: 3px 3px 0 0 var(--color-outline);
    animation: float-a 5s ease-in-out infinite;
  }

  .dot-2 {
    background: var(--color-coral);
    top: 35%;
    right: 20%;
    opacity: 0.8;
    box-shadow: 3px 3px 0 0 var(--color-outline);
    animation: float-b 6.5s ease-in-out infinite;
  }

  .dot-3 {
    background: var(--color-accent);
    bottom: 30%;
    left: 22%;
    opacity: 0.7;
    box-shadow: 3px 3px 0 0 var(--color-outline);
    animation: float-a 7.5s ease-in-out infinite reverse;
  }

  /* Squiggles */
  .shape--squiggle {
    border: none;
    width: 140px;
    color: var(--color-accent);
    top: 12%;
    right: 22%;
    opacity: 0.6;
    transform: rotate(-10deg);
    animation: float-b 8s ease-in-out infinite;
  }

  .squiggle-2 {
    color: var(--color-coral);
    top: auto;
    right: auto;
    bottom: 18%;
    left: 30%;
    opacity: 0.5;
    transform: rotate(5deg);
    width: 100px;
    animation: float-a 10s ease-in-out infinite;
  }

  @keyframes float-a {
    0%,
    100% {
      transform: translateY(0px) rotate(var(--shape-rot, 0deg));
    }
    50% {
      transform: translateY(-14px) rotate(var(--shape-rot, 0deg));
    }
  }

  @keyframes float-b {
    0%,
    100% {
      transform: translateY(0px) rotate(var(--shape-rot, 18deg));
    }
    50% {
      transform: translateY(10px) rotate(var(--shape-rot, 18deg));
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
    max-width: 780px;
    width: 100%;
  }

  .hero__title-card {
    display: inline-block;
    background-color: var(--color-primary);
    border: 4px solid var(--color-outline);
    box-shadow: 10px 10px 0 0 var(--color-outline);
    border-radius: var(--radius-md);
    padding: 1.5rem 3rem 1.75rem;
    transform: rotate(-1.5deg);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    /* Prevent layout shift from rotation eating into siblings */
    margin-bottom: 0.5rem;
  }

  .hero__title-card:hover {
    transform: rotate(-0.5deg) translateY(-4px);
    box-shadow: 14px 14px 0 0 var(--color-outline);
  }

  .hero__title {
    font-family: "Lexend Mega", sans-serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 700;
    line-height: 0.91;
    color: var(--color-black);
    letter-spacing: -0.156em;
    text-transform: uppercase;
  }

  .hero__tagline {
    font-size: clamp(1.2rem, 3vw, 1.75rem);
    font-weight: 600;
    line-height: 1.33;
    color: var(--color-text);
    letter-spacing: 0;
    max-width: 600px;
  }

  .hero__description {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--color-text-secondary);
    max-width: 520px;
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-outline);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.75rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 2rem;
    border: var(--border-width) solid var(--color-outline);
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-black);
    text-decoration: none;
    cursor: pointer;
    transition:
      box-shadow 0.15s ease,
      transform 0.15s ease;
    /* Default shadow state */
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 0
      var(--color-outline);
    /* Prevent text selection on rapid clicks */
    user-select: none;
  }

  .btn--ios {
    background-color: var(--color-tertiary);
  }

  .btn--android {
    background-color: var(--color-secondary);
  }

  .btn:hover {
    transform: translate(-3px, -3px);
    box-shadow: 12px 12px 0 0 var(--color-outline);
  }

  .btn:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .btn:active {
    transform: translate(2px, 2px);
    box-shadow: 3px 3px 0 0 var(--color-outline);
  }

  .btn__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .btn__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.1;
  }

  .btn__label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.75;
  }

  .btn__platform {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0;
  }

  .hero__scroll-nudge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    opacity: 0.65;
    animation: bounce-down 2.5s ease-in-out infinite;
  }

  .scroll-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .scroll-arrow {
    flex-shrink: 0;
  }

  @keyframes bounce-down {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* Hide inline breaks on wide screens — they only serve mobile */
  @media (min-width: 640px) {
    .tagline-break,
    .desc-break {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 5rem 1.25rem 4rem;
    }

    .hero__title-card {
      padding: 1.25rem 1.75rem 1.5rem;
      /* Reduce shadow on small screens so it doesn't clip */
      box-shadow: 6px 6px 0 0 var(--color-outline);
    }

    .hero__title-card:hover {
      box-shadow: 8px 8px 0 0 var(--color-outline);
    }

    .hero__ctas {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    /* Tuck large background shapes further out of frame on small screens */
    .shape--circle-lg {
      width: 180px;
      height: 180px;
      top: -60px;
      left: -60px;
    }

    .shape--square {
      width: 90px;
      height: 90px;
      top: 40px;
      right: 4%;
    }

    .shape--squiggle {
      display: none;
    }

    .squiggle-2 {
      display: none;
    }
  }

  /* Reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .shape,
    .hero__scroll-nudge {
      animation: none;
    }

    .hero__title-card {
      transition: none;
    }

    .btn {
      transition: none;
    }
  }
</style>
