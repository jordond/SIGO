---
import { Image } from "astro:assets"
import screenshotYes from "../assets/ios_forecast_yes.png"
import DownloadButtons from "./DownloadButtons.astro"
---

<section class="hero">
  <div class="bg-shapes" aria-hidden="true">
    <div class="shape shape--circle-lg"></div>
    <div class="shape shape--square"></div>
    <div class="shape shape--circle-sm"></div>
    <div class="shape shape--rect"></div>
    <div class="shape shape--dot dot-1"></div>
    <div class="shape shape--dot dot-2"></div>
    <div class="shape shape--dot dot-3"></div>
    <div class="shape shape--squiggle">
      <svg viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M4 20 C20 4, 36 36, 52 20 C68 4, 84 36, 100 20 C108 12, 114 16, 118 20"
          stroke="currentColor"
          stroke-width="5"
          stroke-linecap="round"
          fill="none"></path>
      </svg>
    </div>
    <div class="shape shape--squiggle squiggle-2">
      <svg viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M4 20 C20 4, 36 36, 52 20 C68 4, 84 36, 100 20 C108 12, 114 16, 118 20"
          stroke="currentColor"
          stroke-width="5"
          stroke-linecap="round"
          fill="none"></path>
      </svg>
    </div>
  </div>

  <!-- Main content -->
  <div class="hero__inner">
    <!-- Text column -->
    <div class="hero__text">
      <!-- Tilted headline card -->
      <div class="hero__title-card">
        <h1 class="hero__title">Should I<br />Go Outside?</h1>
      </div>

      <!-- Tagline -->
      <p class="hero__tagline">
        The weather app that answers<br class="tagline-break" /> the only question
        that matters.
      </p>

      <!-- Description -->
      <p class="hero__description">
        No radar maps. No pollen counts. No 10-day forecasts you'll never read.<br
          class="desc-break"
        />
        Just the answer you actually need.
      </p>

      <!-- CTA buttons -->
      <DownloadButtons />
    </div>

    <!-- Phone screenshot -->
    <div class="hero__phone-wrap">
      <div class="hero__phone">
        <Image
          src={screenshotYes}
          alt="Should I Go Outside app showing a Yes answer with temperature, wind, rain, and air quality conditions"
          class="hero__phone-screenshot"
          width={600}
          loading="eager"
        />
      </div>
    </div>

    <!-- Scroll nudge -->
    <div class="hero__scroll-nudge" aria-hidden="true">
      <span class="scroll-label">scroll to find out more</span>
      <svg
        class="scroll-arrow"
        width="20"
        height="24"
        viewBox="0 0 20 28"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line
          x1="10"
          y1="0"
          x2="10"
          y2="20"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"></line>
        <polyline
          points="3,14 10,22 17,14"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"></polyline>
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg);
    overflow: hidden;
    padding: 6rem 1.5rem 5rem;
  }

  .bg-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .shape {
    position: absolute;
    border: var(--border-width) solid var(--color-outline);
  }

  /* Large circle — top left */
  .shape--circle-lg {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background-color: var(--color-secondary);
    top: -80px;
    left: -80px;
    opacity: 0.45;
    box-shadow: var(--shadow-offset-lg) var(--shadow-offset-lg) 0 0
      var(--color-outline);
    animation: float-a 7s ease-in-out infinite;
  }

  /* Tilted square — top right */
  .shape--square {
    width: 140px;
    height: 140px;
    border-radius: var(--radius-sm);
    background-color: var(--color-tertiary);
    top: 60px;
    right: 8%;
    opacity: 0.35;
    transform: rotate(18deg);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    animation: float-b 9s ease-in-out infinite;
  }

  /* Small circle — right mid */
  .shape--circle-sm {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background-color: var(--color-mint);
    right: 12%;
    bottom: 22%;
    opacity: 0.5;
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    animation: float-a 6s ease-in-out infinite reverse;
  }

  /* Rectangle — bottom left */
  .shape--rect {
    width: 200px;
    height: 80px;
    border-radius: var(--radius-sm);
    background-color: var(--color-orange);
    bottom: 10%;
    left: 4%;
    opacity: 0.3;
    transform: rotate(-8deg);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    animation: float-b 8s ease-in-out infinite;
  }

  /* Dots */
  .shape--dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: none;
  }

  .dot-1 {
    background: var(--color-primary);
    top: 18%;
    left: 18%;
    opacity: 0.9;
    box-shadow: 3px 3px 0 0 var(--color-outline);
    animation: float-a 5s ease-in-out infinite;
  }

  .dot-2 {
    background: var(--color-coral);
    top: 35%;
    right: 20%;
    opacity: 0.8;
    box-shadow: 3px 3px 0 0 var(--color-outline);
    animation: float-b 6.5s ease-in-out infinite;
  }

  .dot-3 {
    background: var(--color-accent);
    bottom: 30%;
    left: 22%;
    opacity: 0.7;
    box-shadow: 3px 3px 0 0 var(--color-outline);
    animation: float-a 7.5s ease-in-out infinite reverse;
  }

  /* Squiggles */
  .shape--squiggle {
    border: none;
    width: 140px;
    color: var(--color-accent);
    top: 12%;
    right: 22%;
    opacity: 0.6;
    transform: rotate(-10deg);
    animation: float-b 8s ease-in-out infinite;
  }

  .squiggle-2 {
    color: var(--color-coral);
    top: auto;
    right: auto;
    bottom: 18%;
    left: 30%;
    opacity: 0.5;
    transform: rotate(5deg);
    width: 100px;
    animation: float-a 10s ease-in-out infinite;
  }

  @keyframes float-a {
    0%,
    100% {
      transform: translateY(0px) rotate(var(--shape-rot, 0deg));
    }
    50% {
      transform: translateY(-14px) rotate(var(--shape-rot, 0deg));
    }
  }

  @keyframes float-b {
    0%,
    100% {
      transform: translateY(0px) rotate(var(--shape-rot, 18deg));
    }
    50% {
      transform: translateY(10px) rotate(var(--shape-rot, 18deg));
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    max-width: 1100px;
    width: 100%;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
    flex: 1 1 0%;
  }

  /* ── Hero phone ── */
  .hero__phone-wrap {
    flex: 1 1 0%;
    display: flex;
    justify-content: center;
    align-items: center;
    transform: rotate(3deg) translateY(10px);
    animation: float-a 6s ease-in-out infinite;
  }

  .hero__phone {
    position: relative;
    width: 280px;
    border-radius: 36px;
    border: 3px solid var(--color-outline);
    padding: 5px;
    background-color: var(--color-outline);
    box-shadow: 8px 10px 0 0 var(--color-outline);
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .hero__phone:hover {
    transform: translateY(-6px);
    box-shadow: 12px 14px 0 0 var(--color-outline);
  }

  .hero__phone-screenshot {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 31px;
  }

  .hero__title-card {
    display: inline-block;
    background-color: var(--color-primary);
    border: 4px solid var(--color-outline);
    box-shadow: 10px 10px 0 0 var(--color-outline);
    border-radius: var(--radius-md);
    padding: 1.5rem 3rem 1.75rem;
    transform: rotate(-1.5deg);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    /* Prevent layout shift from rotation eating into siblings */
    margin-bottom: 0.5rem;
  }

  .hero__title-card:hover {
    transform: rotate(-0.5deg) translateY(-4px);
    box-shadow: 14px 14px 0 0 var(--color-outline);
  }

  .hero__title {
    font-family: "Lexend Mega", sans-serif;
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 700;
    line-height: 0.91;
    color: var(--color-black);
    letter-spacing: -0.156em;
    text-transform: uppercase;
  }

  .hero__tagline {
    font-size: clamp(1.2rem, 3vw, 1.75rem);
    font-weight: 600;
    line-height: 1.33;
    color: var(--color-text);
    letter-spacing: 0;
    max-width: 600px;
  }

  .hero__description {
    font-size: clamp(1rem, 2vw, 1.2rem);
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--color-text-secondary);
    max-width: 520px;
    background-color: var(--color-white);
    border: var(--border-width) solid var(--color-outline);
    box-shadow: var(--shadow-offset) var(--shadow-offset) 0 0
      var(--color-outline);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.75rem;
  }


  .hero__scroll-nudge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    color: var(--color-text-secondary);
    opacity: 0.65;
    animation: bounce-down 2.5s ease-in-out infinite;
  }

  .scroll-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .scroll-arrow {
    flex-shrink: 0;
  }

  @keyframes bounce-down {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* Hide inline breaks on wide screens — they only serve mobile */
  @media (min-width: 640px) {
    .tagline-break,
    .desc-break {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .hero__inner {
      flex-direction: column;
      gap: 2.5rem;
    }

    .hero__phone-wrap {
      transform: rotate(2deg);
    }

    .hero__phone {
      width: 220px;
      border-radius: 30px;
    }

    .hero__phone-screenshot {
      border-radius: 25px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 5rem 1.25rem 4rem;
    }

    .hero__title-card {
      padding: 1.25rem 1.75rem 1.5rem;
      box-shadow: 6px 6px 0 0 var(--color-outline);
    }

    .hero__title-card:hover {
      box-shadow: 8px 8px 0 0 var(--color-outline);
    }

    .hero__phone-wrap {
      transform: rotate(1.5deg);
    }

    .hero__phone {
      width: 200px;
      border-radius: 26px;
      box-shadow: 6px 8px 0 0 var(--color-outline);
    }

    .hero__phone-screenshot {
      border-radius: 22px;
    }

    /* Tuck large background shapes further out of frame on small screens */
    .shape--circle-lg {
      width: 180px;
      height: 180px;
      top: -60px;
      left: -60px;
    }

    .shape--square {
      width: 90px;
      height: 90px;
      top: 40px;
      right: 4%;
    }

    .shape--squiggle {
      display: none;
    }

    .squiggle-2 {
      display: none;
    }
  }

  /* Reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    .shape,
    .hero__scroll-nudge,
    .hero__phone-wrap {
      animation: none;
    }

    .hero__title-card,
    .hero__phone {
      transition: none;
    }
  }
</style>
