---
import DownloadButtons from "./DownloadButtons.astro"

const currentYear = new Date().getFullYear()

const links = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
  { label: "Help", href: "/help" },
  { label: "Contact", href: "mailto:contact@toebeans.life" },
] as const
---

<section class="cta" aria-labelledby="cta-heading">
  <div class="cta__inner">
    <!-- Decorative tick marks — pure CSS via pseudo-elements -->
    <div class="cta__tick cta__tick--left" aria-hidden="true"></div>
    <div class="cta__tick cta__tick--right" aria-hidden="true"></div>

    <h2 class="cta__heading reveal" id="cta-heading">
      Ready to Never Overthink<br />Weather Again?
    </h2>

    <p class="cta__sub">One tap. One answer. Get outside already.</p>

    <DownloadButtons />
  </div>
</section>

<footer class="footer" role="contentinfo">
  <!-- Colored accent stripe at very top of dark footer -->
  <div class="footer__accent-stripe" aria-hidden="true"></div>

  <div class="footer__inner">
    <!-- Left: brand -->
    <div class="footer__brand">
      <p class="footer__app-name">Should I Go Outside?</p>
      <p class="footer__tagline">
        The only weather app that answers<br />the only question that matters.
      </p>
    </div>

    <!-- Center: links -->
    <nav class="footer__nav" aria-label="Footer navigation">
      <ul class="footer__nav-list" role="list">
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="footer__nav-link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right: social icons -->
    <div class="footer__social" aria-label="Social media links">
      <a
        href="https://github.com/jordond/sigo"
        class="footer__social-link"
        aria-label="View our GitHub"
      >
        <!-- GitHub -->
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path>
        </svg>
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {currentYear} Should I Go Outside? All rights reserved.
      </p>
    </div>
  </div>

  <style>
    .cta {
      background-color: var(--color-primary);
      border-top: var(--border-width) solid var(--color-outline);
      border-bottom: var(--border-width) solid var(--color-outline);
      padding: 5rem 1.5rem;
      position: relative;
      overflow: hidden;
    }

    .cta__inner {
      max-width: 720px;
      margin-inline: auto;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    /* ── Decorative tick marks ── */
    .cta__tick {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 48px;
      height: 80%;
      pointer-events: none;
    }

    .cta__tick--left {
      left: 2rem;
    }
    .cta__tick--right {
      right: 2rem;
      transform: translateY(-50%) scaleX(-1);
    }

    .cta__tick::before,
    .cta__tick::after {
      content: "";
      position: absolute;
      left: 50%;
      width: var(--border-width);
      background-color: var(--color-black);
      opacity: 0.18;
    }
    .cta__tick::before {
      top: 0;
      height: 40%;
      transform: translateX(-50%) rotate(-10deg);
    }
    .cta__tick::after {
      bottom: 0;
      height: 40%;
      transform: translateX(-50%) rotate(10deg);
    }

    /* ── Heading ── */
    .cta__heading {
      font-family: "Lexend Mega", sans-serif;
      font-size: clamp(2rem, 5.5vw, 3.5rem);
      font-weight: 700;
      line-height: 0.93;
      letter-spacing: -0.2em;
      text-transform: uppercase;
      color: var(--color-text);
      margin-bottom: 1rem;
    }

    .cta__sub {
      font-size: 1.05rem;
      font-weight: 500;
      line-height: 1.5;
      letter-spacing: 0;
      color: var(--color-text-secondary);
      margin-bottom: 2.5rem;
    }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      .cta {
        padding: 4rem 1.25rem;
      }

      .cta__tick {
        display: none;
      }
    }

    .footer {
      background-color: var(--color-text);
      color: var(--color-white);
    }

    /* Accent stripe — a 4px slash of yellow across the top edge */
    .footer__accent-stripe {
      height: 4px;
      background: repeating-linear-gradient(
        90deg,
        var(--color-primary) 0px,
        var(--color-primary) 40px,
        var(--color-tertiary) 40px,
        var(--color-tertiary) 80px,
        var(--color-secondary) 80px,
        var(--color-secondary) 120px
      );
    }

    /* ── Main columns row ── */
    .footer__inner {
      max-width: 900px;
      margin-inline: auto;
      padding: 3.5rem 1.5rem 2.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 2.5rem;
      align-items: flex-start;
      justify-content: space-between;
    }

    /* ── Brand block ── */
    .footer__brand {
      flex: 1 1 200px;
    }

    .footer__app-name {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0;
      color: var(--color-primary);
      margin-bottom: 0.6rem;
      /* Left-aligned tick mark */
      padding-left: 0.85rem;
      border-left: 3px solid var(--color-primary);
      line-height: 1.3;
    }

    .footer__tagline {
      font-size: 0.875rem;
      font-weight: 400;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.55);
      padding-left: 0.85rem;
    }

    /* ── Nav block ── */
    .footer__nav {
      flex: 0 1 auto;
      align-self: center;
    }

    .footer__nav-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer__nav-link {
      font-size: 0.9rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.65);
      text-decoration: none;
      letter-spacing: 0.01em;
      line-height: 1.43;
      position: relative;
      transition: color 150ms ease;
    }

    /* Underline that slides in from the left on hover */
    .footer__nav-link::after {
      content: "";
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 2px;
      background-color: var(--color-primary);
      transition: width 200ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .footer__nav-link:hover,
    .footer__nav-link:focus-visible {
      color: var(--color-white);
      outline: none;
    }

    .footer__nav-link:hover::after,
    .footer__nav-link:focus-visible::after {
      width: 100%;
    }

    .footer__nav-link:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 3px;
      border-radius: 2px;
    }

    /* ── Social block ── */
    .footer__social {
      flex: 0 1 auto;
      display: flex;
      gap: 0.75rem;
      align-items: center;
      align-self: center;
    }

    .footer__social-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border: var(--border-width) solid rgba(255, 255, 255, 0.2);
      border-radius: var(--radius-sm);
      color: rgba(255, 255, 255, 0.65);
      text-decoration: none;
      box-shadow: 3px 3px 0 0 rgba(255, 255, 255, 0.08);
      transform: translate(0, 0);
      transition:
        color 150ms ease,
        border-color 150ms ease,
        transform 120ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 120ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .footer__social-link:hover,
    .footer__social-link:focus-visible {
      color: var(--color-primary);
      border-color: var(--color-primary);
      transform: translate(3px, 3px);
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.08);
      outline: none;
    }

    .footer__social-link:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }

    .footer__social-link svg {
      width: 1.1rem;
      height: 1.1rem;
      flex-shrink: 0;
    }

    /* ── Bottom copyright bar ── */
    .footer__bottom {
      flex-basis: 100%;
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding: 1.25rem 1.5rem;
      text-align: center;
    }

    .footer__copyright {
      font-size: 0.8rem;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.35);
      letter-spacing: 0.04em;
      line-height: 1.33;
    }

    @media (max-width: 600px) {
      .footer__inner {
        flex-direction: column;
        gap: 2rem;
        padding: 2.5rem 1.25rem 2rem;
        align-items: flex-start;
      }

      .footer__brand,
      .footer__nav,
      .footer__social {
        flex: none;
        width: 100%;
      }

      .footer__social {
        justify-content: flex-start;
      }

      .footer__bottom {
        padding: 1rem 1.25rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .footer__social-link {
        transition: none;
      }

      .footer__nav-link::after {
        transition: none;
      }
    }
  </style>
</footer>
