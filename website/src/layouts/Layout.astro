---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Should I Go Outside? | The Weather App That Answers the Only Question That Matters",
	description = "Stop checking complicated weather apps. Should I Go Outside? cuts through the noise and gives you the only answer you actually need. Real weather data, zero confusion.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />

		<!-- Google Fonts: Space Grotesk -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	:root {
		/* Colors */
		--color-bg: #feecde;
		--color-surface: #fff5ea;
		--color-text: #111111;
		--color-text-secondary: #333333;
		--color-primary: #ffdb02;
		--color-secondary: #87ceeb;
		--color-tertiary: #ff69b4;
		--color-accent: #a388ee;
		--color-coral: #ff6b6b;
		--color-mint: #90ee90;
		--color-orange: #ff8c42;
		--color-outline: #000000;
		--color-shadow: #000000;
		--color-white: #ffffff;
		--color-black: #000000;

		/* Brutal design tokens */
		--border-width: 3px;
		--shadow-offset: 4px;
		--shadow-offset-lg: 8px;
		--radius-sm: 4px;
		--radius-md: 8px;
		--radius-lg: 16px;
	}

	html {
		scroll-behavior: smooth;
		font-size: 16px;
	}

	body {
		font-family: 'Space Grotesk', sans-serif;
		font-weight: 400;
		line-height: 1.6;
		background-color: var(--color-bg);
		color: var(--color-text);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		text-rendering: optimizeLegibility;
	}

	.brutal-border {
		border: var(--border-width) solid var(--color-outline);
	}

	.brutal-shadow {
		box-shadow:
			var(--shadow-offset) var(--shadow-offset) 0 0 var(--color-shadow);
	}

	.brutal-shadow-lg {
		box-shadow:
			var(--shadow-offset-lg) var(--shadow-offset-lg) 0 0 var(--color-shadow);
	}

	.brutal-card {
		border: var(--border-width) solid var(--color-outline);
		box-shadow:
			var(--shadow-offset) var(--shadow-offset) 0 0 var(--color-shadow);
		background-color: var(--color-surface);
		padding: 1.5rem;
		border-radius: var(--radius-md);
	}
</style>
