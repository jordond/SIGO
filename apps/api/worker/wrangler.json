{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sigo-api-worker",
  "main": "index.mjs",
  "compatibility_date": "2026-02-25",
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "FORECAST_CACHE",
      "id": "76a504d795c94147a7dd6abdc95589f8"
    }
  ],
  "routes": [
    {
      "pattern": "api.shouldigooutside.now",
      "custom_domain": true,
      "zone_name": "shouldigooutside.now"
    }
  ],
  "env": {
    "staging": {
      "name": "sigo-api-staging",
      "routes": [
        {
          "pattern": "staging.api.shouldigooutside.now",
          "custom_domain": true,
          "zone_name": "shouldigooutside.now"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "FORECAST_CACHE",
          "id": "fd8858df78bb43a0991c6d4520a02494",
          "remote": true
        }
      ]
    },
    "dev": {
      "name": "sigo-api-dev",
      "routes": [
        {
          "pattern": "dev.api.shouldigooutside.now",
          "custom_domain": true,
          "zone_name": "shouldigooutside.now"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "FORECAST_CACHE",
          "id": "dee0269597ea4b7d87d241bf727177c1",
          "remote": true
        }
      ]
    }
  }
}