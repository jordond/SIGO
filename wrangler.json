{
  "$schema": "apps/api/worker/node_modules/wrangler/config-schema.json",
  "name": "sigo-api-worker",
  "main": "apps/api/worker/index.mjs",
  "compatibility_date": "2026-02-25",
  "compatibility_flags": ["nodejs_compat_v2"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "FORECAST_CACHE",
      "id": "76a504d795c94147a7dd6abdc95589f8"
    }
  ],
  "routes": [
    {
      "pattern": "api.shouldigooutside.now",
      "custom_domain": true,
      "zone_name": "shouldigooutside.now"
    }
  ],
  "env": {
    "staging": {
      "name": "sigo-api-staging",
      "routes": [
        {
          "pattern": "staging.api.shouldigooutside.now",
          "custom_domain": true,
          "zone_name": "shouldigooutside.now"
        }
      ]
    },
    "dev": {
      "name": "sigo-api-dev",
      "routes": [
        {
          "pattern": "dev.api.shouldigooutside.now",
          "custom_domain": true,
          "zone_name": "shouldigooutside.now"
        }
      ]
    }
  }
}
