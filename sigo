#!/bin/bash

# This script is a wrapper around the various scripts in the scripts folder.

# Explode on errors 💥
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"

print_usage() {
    echo "Usage:"
    echo "    $0 <command> [args]"
    echo " "
    echo "Commands:"
    echo "    help                           Show this help message"
    echo "    init [command] [arguments]     Initialize a project component"
    echo "          ktlint|k [arguments]     Install ktlint and integrate it with the project"
    echo "          hooks|h [--output]       Install the git hooks, pass --output to display the contents of the hooks"
    echo "          api:worker               Install required dependencies for the api worker"
    echo "    gradle <command>               Run any gradle command"
    echo "    add <component>                Add a lumo ui component"
    echo "    lint --all | --staged [args]   Lint the codebase using ktlint"
    echo "    fix [--all] [--staged]         Fixes only staged files if --all is not passed"
    echo "    commit|c [options]             Stage changes, run fix, and commit"
    echo "    cli [args]                     Run the CLI version of SIGO"
    echo "    api                            Commands for the API"
    echo "    api:server <command>           Run command helpers for the JVM API server"
    echo "    api:worker <command>           Run command helpers for the api worker"
    echo "    release:app [options]          Release both Android and iOS"
    echo "    release:app:android [options]  Build and release Android AAB"
    echo "    release:app:ios [options]      Bump iOS version and prepare for Xcode release"
    echo "    release:api [options]          Release and deploy the API worker"
    echo "    website dev                     Start the website dev server"
    echo "    release:website [options]       Deploy the website to Cloudflare"
    echo "          --env <env>              Target environment: prod (default) or staging"
    echo "          --dry-run                Run wrangler deploy in dry-run mode"
}

check_directory() {
    local current_dir
    current_dir="$(pwd)"

    if [ "$ROOT" != "$current_dir" ]; then
        echo "Error: This script must be run from the directory containing the 'sigo' script."
        echo "Please navigate to $ROOT and try again."
        exit 1
    fi
}

# If no arguments are passed, show the help message
if [ "$#" -eq 0 ]; then
    print_usage
    exit 0
fi

case "$1" in
help)
    print_usage
    exit 0
    ;;
init)
    shift
    if [ "$#" -eq 0 ]; then
        "$ROOT"/scripts/init.sh
        # Return the exit code of the init.sh
        if [ $? -eq 0 ]; then
            echo "✅ Project initialized successfully"
            exit 0
        else
            echo "❌ Project initialization failed"
            exit 1
        fi
    fi
    subcommand=$1
    shift

    case "$subcommand" in
    ktlint | lint | k)
        "$ROOT"/scripts/init-ktlint.sh "$@"
        ;;
    hooks | hook | h)
        "$ROOT"/scripts/init-hooks.sh "$@"
        ;;
    api:worker)
        "$ROOT"/scripts/api-worker.sh init
        ;;
    *)
        echo "The command '$subcommand' is not a valid 'init' command. Use 'ktlint' or 'hooks'."
        exit 1
        ;;
    esac
    ;;
gradle | g)
    shift
    "$ROOT"/gradlew "$@"
    ;;
add)
    shift
    # Check if there is a component name:
    if [ "$#" -eq 0 ]; then
        echo "Error: No component name provided"
        exit 1
    fi
    "$ROOT"/gradlew lumo --no-configuration-cache --add "$@"
    ;;
lint | l)
    shift
    "$ROOT"/scripts/ktlint.sh "$@"
    ;;
fix | f)
    if [[ "${2:-}" == "--all" ]]; then
        set +e
        echo "Linting and fixing all kotlin files"
        "$ROOT"/scripts/ktlint.sh --all -F

        echo "Formatting all shell scripts"
        shfmt -w -i 4 "$ROOT"/scripts/
    else
        "$ROOT"/scripts/hooks/pre-commit -F
    fi
    ;;
commit | c)
    shift # Remove the 'commit' command from arguments

    echo "📦 Staging all changes..."
    git add --all

    echo "🔍 Running fix on staged files..."
    # Suppress output except for errors
    if ! "$ROOT"/scripts/hooks/pre-commit -F; then
        echo "❌ Error running pre-commit hook"
        exit 1
    fi

    echo "📦 Re-staging all changes..."
    git add --all

    echo "💾 Committing changes..."
    # Check if any arguments were provided
    if [ $# -eq 0 ]; then
        git commit --no-verify
    # Check if -m flag is present
    elif [[ "$1" == "-m" ]]; then
        shift # Remove -m flag
        commit_msg="$*"
        git commit -m "$commit_msg" --no-verify
    else
        # Pass all arguments directly to git commit
        git commit --no-verify "$@"
    fi
    ;;
xcode)
    echo "Opening Xcode workspace"
    open "$ROOT/apps/ios/iosApp.xcodeproj"
    ;;
cli)
    shift
    "$ROOT"/scripts/cli.sh "$@"
    ;;
api)
    shift
    "$ROOT"/scripts/api.sh "$@"
    ;;
api:server)
    shift
    "$ROOT"/scripts/api-server.sh "$@"
    ;;
api:worker)
    shift
    "$ROOT"/scripts/api-worker.sh "$@"
    ;;
release:app:android)
    shift
    "$ROOT"/scripts/release-android.sh "$@"
    ;;
release:app:ios)
    shift
    "$ROOT"/scripts/release-ios.sh "$@"
    ;;
release:app)
    shift
    "$ROOT"/scripts/release-app.sh "$@"
    ;;
release:api)
    shift
    "$ROOT"/scripts/release-api.sh "$@"
    ;;
release:website)
    shift
    "$ROOT"/scripts/release-website.sh "$@"
    ;;
website)
    shift
    case "${1:-}" in
    dev)
        (cd "$ROOT/website" && pnpm run dev)
        ;;
    *)
        echo "Unknown website command: ${1:-}"
        echo "Usage: $0 website dev"
        exit 1
        ;;
    esac
    ;;
*)
    echo "Unknown command: $1"
    echo ""
    print_usage
    exit 1
    ;;
esac
